---
import PreviewLayout from "../layouts/PreviewLayout.astro";

const options = [
  {
    href: "/instrument",
    n: "01",
    name: "Instrument panel",
    note: "Dark-first. Monospace data labels, one phosphor-amber accent, an ambient request-trace waterfall in the hero. Reads like a well-made observability tool.",
    tags: ["dark + light", "Space Grotesk", "JetBrains Mono"],
  },
  {
    href: "/schema",
    n: "02",
    name: "Typed schema",
    note: "Light-first. The whole page is framed as a source file — the name renders as a giant string value inside a type declaration. Syntax-highlight colours are the palette.",
    tags: ["light + dark", "IBM Plex Sans", "IBM Plex Mono"],
  },
  {
    href: "/object",
    n: "03",
    name: "Object-native",
    note: "Adapted from your futureos design language. Warm paper, one electric-blue accent, a faint drafting grid, and the object:// typed-address motif with semantic category dots. Bricolage Grotesque display.",
    tags: ["light + dark", "Bricolage Grotesque", "IBM Plex Mono"],
  },
];
---

<PreviewLayout
  title="Choose a direction — Kamil Kruszona portfolio"
  description="Three design directions to pick from."
>
  <main class="pick">
    <header class="pick-bar">
      <span class="pick-brand">sapirowsky / portfolio</span>
      <button type="button" data-theme-toggle class="pick-toggle" aria-label="Toggle colour theme">
        <span class="theme-dark-icon">☀ Light</span>
        <span class="theme-light-icon">☾ Dark</span>
      </button>
    </header>

    <section class="pick-intro">
      <p class="pick-eyebrow">Preview · pick one</p>
      <h1 class="pick-title">Three directions.</h1>
      <p class="pick-lead">
        Open each, toggle light/dark, then tell me which one to finish. I'll polish the
        winner and delete the other two.
      </p>
    </section>

    <ul class="pick-list">
      {
        options.map((opt) => (
          <li>
            <a class="pick-card" href={opt.href}>
              <span class="pick-n">{opt.n}</span>
              <span class="pick-body">
                <span class="pick-name">{opt.name}</span>
                <span class="pick-note">{opt.note}</span>
                <span class="pick-tags">
                  {opt.tags.map((t) => (
                    <span class="pick-tag">{t}</span>
                  ))}
                </span>
              </span>
              <span class="pick-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>

  <style is:global>
    html[data-theme="dark"] .pick {
      --bg: #0d0e10;
      --fg: #eceef0;
      --muted: #8a929a;
      --line: rgba(255, 255, 255, 0.1);
      --panel: #15171a;
      --accent: #ffb000;
    }
    html[data-theme="light"] .pick {
      --bg: #f4f2ec;
      --fg: #16181a;
      --muted: #63696f;
      --line: rgba(22, 24, 26, 0.12);
      --panel: #ffffff;
      --accent: #1f34ff;
    }

    .pick {
      min-height: 100svh;
      background: var(--bg);
      color: var(--fg);
      font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
      transition: background 0.4s ease, color 0.4s ease;
    }
    .pick-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 880px;
      margin: 0 auto;
      padding: 22px 24px;
    }
    .pick-brand {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.85rem;
      color: var(--muted);
    }
    .pick-toggle {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.82rem;
      background: transparent;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 7px 12px;
      color: var(--fg);
      cursor: pointer;
    }
    .pick-toggle:hover { border-color: var(--accent); color: var(--accent); }
    .pick-toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
    html[data-theme="dark"] .theme-light-icon { display: none; }
    html[data-theme="light"] .theme-dark-icon { display: none; }

    .pick-intro {
      max-width: 880px;
      margin: 0 auto;
      padding: clamp(36px, 7vw, 72px) 24px clamp(24px, 3vw, 36px);
    }
    .pick-eyebrow {
      font-family: "JetBrains Mono", monospace;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 0.75rem;
      color: var(--accent);
      margin: 0 0 18px;
    }
    .pick-title {
      font-family: "Space Grotesk", sans-serif;
      font-weight: 600;
      font-size: clamp(2.4rem, 7vw, 4rem);
      letter-spacing: -0.03em;
      margin: 0;
    }
    .pick-lead {
      max-width: 52ch;
      margin: 20px 0 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 1.05rem;
    }

    .pick-list {
      list-style: none;
      max-width: 880px;
      margin: 0 auto;
      padding: 0 24px clamp(48px, 8vw, 90px);
      display: grid;
      gap: 14px;
    }
    .pick-card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: clamp(16px, 3vw, 28px);
      align-items: start;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--panel);
      padding: clamp(22px, 3vw, 30px);
      transition: border-color 0.22s ease, transform 0.22s ease;
    }
    .pick-card:hover { border-color: var(--accent); transform: translateY(-3px); }
    .pick-card:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
    .pick-n {
      font-family: "JetBrains Mono", monospace;
      color: var(--accent);
      font-size: 0.9rem;
      padding-top: 4px;
    }
    .pick-name {
      display: block;
      font-family: "Space Grotesk", sans-serif;
      font-weight: 600;
      font-size: 1.35rem;
      letter-spacing: -0.01em;
    }
    .pick-note {
      display: block;
      margin: 10px 0 16px;
      color: var(--muted);
      line-height: 1.55;
      font-size: 0.96rem;
    }
    .pick-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .pick-tag {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.72rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 4px 10px;
      color: var(--muted);
    }
    .pick-arrow {
      font-size: 1.3rem;
      color: var(--accent);
      transition: transform 0.22s ease;
    }
    .pick-card:hover .pick-arrow { transform: translateX(4px); }

    @media (max-width: 560px) {
      .pick-card { grid-template-columns: auto 1fr; }
      .pick-arrow { display: none; }
    }
  </style>
</PreviewLayout>
