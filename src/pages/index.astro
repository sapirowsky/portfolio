---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile, stackGroups, strengths } from "../data/profile";

const pageDescription =
  "Sapir Sapirsky is a full-stack product engineer working with TypeScript, React, Laravel, APIs, and practical infrastructure.";
---

<BaseLayout title={`${profile.name} | ${profile.role}`} description={pageDescription}>
  <main>
    <section class="min-h-[92svh] border-b border-line bg-paper">
      <div class="mx-auto flex min-h-[92svh] w-full max-w-6xl flex-col px-5 py-6 sm:px-8 lg:px-10">
        <header class="flex items-center justify-between gap-4">
          <a href="/" class="flex items-center gap-3 font-semibold" aria-label={`${profile.name} home`}>
            <span class="grid size-10 place-items-center rounded-lg bg-ink text-paper">S</span>
            <span>{profile.handle}</span>
          </a>
          <a
            href={profile.githubUrl}
            class="inline-flex h-10 items-center gap-2 rounded-lg border border-ink px-4 text-sm font-semibold transition hover:bg-ink hover:text-paper focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-teal-mark"
            target="_blank"
            rel="noreferrer"
          >
            <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true">
              <path
                fill="currentColor"
                d="M12 .5A11.5 11.5 0 0 0 8.36 22.9c.58.1.79-.25.79-.56v-2.02c-3.22.7-3.9-1.38-3.9-1.38-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.04 1.76 2.72 1.25 3.38.96.11-.75.41-1.25.74-1.54-2.57-.29-5.27-1.28-5.27-5.72 0-1.26.45-2.3 1.19-3.1-.12-.3-.52-1.48.11-3.07 0 0 .97-.31 3.16 1.18a10.98 10.98 0 0 1 5.76 0c2.19-1.49 3.15-1.18 3.15-1.18.64 1.59.24 2.77.12 3.07.74.8 1.18 1.84 1.18 3.1 0 4.45-2.7 5.43-5.28 5.72.42.36.79 1.07.79 2.16v3.02c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .5Z"
              />
            </svg>
            GitHub
          </a>
        </header>

        <div class="grid flex-1 items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr]">
          <div>
            <p class="mb-5 text-sm font-semibold uppercase text-clay">{profile.role}</p>
            <h1 class="max-w-4xl text-5xl font-black leading-none text-ink sm:text-6xl lg:text-7xl">
              {profile.name}
            </h1>
            <p class="mt-7 max-w-2xl text-xl leading-8 text-neutral-700">
              {profile.summary}
            </p>
            <div class="mt-9 flex flex-wrap gap-3">
              <a
                href="#skills"
                class="rounded-lg bg-ink px-5 py-3 text-sm font-semibold text-paper transition hover:bg-neutral-800 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-teal-mark"
              >
                Skills
              </a>
              <a
                href={profile.githubUrl}
                class="rounded-lg border border-line bg-white px-5 py-3 text-sm font-semibold text-ink transition hover:border-ink focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-teal-mark"
                target="_blank"
                rel="noreferrer"
              >
                View GitHub
              </a>
            </div>
          </div>

          <div class="relative min-h-[360px] border border-line bg-white p-5 shadow-[12px_12px_0_#111111]">
            <div class="grid h-full min-h-[320px] grid-cols-6 grid-rows-6 gap-3">
              <div class="col-span-4 row-span-2 rounded-lg bg-ink p-5 text-paper">
                <p class="text-sm text-stone-300">Current focus</p>
                <p class="mt-4 text-2xl font-bold leading-tight">Full-stack systems with typed boundaries.</p>
              </div>
              <div class="col-span-2 row-span-2 rounded-lg bg-teal-mark"></div>
              <div class="col-span-2 row-span-2 rounded-lg border border-line bg-paper p-4">
                <p class="text-sm font-semibold text-neutral-600">Frontend</p>
                <p class="mt-8 text-3xl font-black">TS</p>
              </div>
              <div class="col-span-4 row-span-2 rounded-lg border border-line bg-white p-4">
                <p class="text-sm font-semibold text-neutral-600">Backend</p>
                <p class="mt-8 text-3xl font-black">API</p>
              </div>
              <div class="col-span-3 row-span-2 rounded-lg bg-signal p-4 text-white">
                <p class="text-sm font-semibold">Infra</p>
                <p class="mt-8 text-3xl font-black">Ops</p>
              </div>
              <div class="col-span-3 row-span-2 rounded-lg bg-clay p-4 text-white">
                <p class="text-sm font-semibold">Quality</p>
                <p class="mt-8 text-3xl font-black">Tests</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="border-b border-line bg-white py-20">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 sm:px-8 lg:grid-cols-[0.75fr_1.25fr] lg:px-10">
        <div>
          <p class="text-sm font-semibold uppercase text-clay">Skills</p>
          <h2 class="mt-3 text-3xl font-black text-ink sm:text-4xl">The useful parts.</h2>
          <p class="mt-5 max-w-md leading-7 text-neutral-700">
            No old project gallery. This is the short version of what I can bring into a codebase now.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {strengths.map((strength) => (
            <article class="rounded-lg border border-line bg-stone-50 p-5">
              <h3 class="text-lg font-bold text-ink">{strength.title}</h3>
              <p class="mt-3 leading-7 text-neutral-700">{strength.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-line bg-paper py-20">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 lg:px-10">
        <div class="grid gap-10 lg:grid-cols-[1fr_1.35fr]">
          <div>
            <p class="text-sm font-semibold uppercase text-clay">About</p>
            <h2 class="mt-3 text-3xl font-black text-ink sm:text-4xl">I like software that survives contact with real work.</h2>
          </div>
          <p class="text-lg leading-8 text-neutral-700">{profile.about}</p>
        </div>
      </div>
    </section>

    <section class="bg-white py-20">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 lg:px-10">
        <div class="flex flex-col justify-between gap-5 sm:flex-row sm:items-end">
          <div>
            <p class="text-sm font-semibold uppercase text-clay">Stack</p>
            <h2 class="mt-3 text-3xl font-black text-ink sm:text-4xl">Tools I can be productive with.</h2>
          </div>
          <a
            href={profile.githubUrl}
            class="inline-flex w-fit rounded-lg border border-ink px-5 py-3 text-sm font-semibold transition hover:bg-ink hover:text-paper focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-teal-mark"
            target="_blank"
            rel="noreferrer"
          >
            github.com/{profile.handle}
          </a>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {stackGroups.map((group) => (
            <section class="rounded-lg border border-line bg-stone-50 p-5">
              <h3 class="font-bold text-ink">{group.label}</h3>
              <ul class="mt-5 space-y-3">
                {group.items.map((item) => (
                  <li class="flex items-center gap-3 text-neutral-700">
                    <span class="size-2 rounded-full bg-teal-mark"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
