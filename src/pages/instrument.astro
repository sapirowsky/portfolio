---
import PreviewLayout from "../layouts/PreviewLayout.astro";
import { focus, profile, stack } from "../data/profile";

const spans = [
  { label: "GET /api/collections", ms: 78, left: 0, width: 100, root: true },
  { label: "authorize()", ms: 6, left: 3, width: 8 },
  { label: "select * from items", ms: 34, left: 13, width: 44 },
  { label: "meilisearch.search", ms: 14, left: 60, width: 18 },
  { label: "otel.export", ms: 5, left: 82, width: 12 },
];
---

<PreviewLayout
  title={`${profile.name} — ${profile.role}`}
  description={profile.tagline}
>
  <main class="inst">
    <div class="inst-grain" aria-hidden="true"></div>

    <header class="inst-bar">
      <a href="/" class="inst-brand">
        <span class="inst-dot" aria-hidden="true"></span>
        <span>{profile.handle}</span>
      </a>
      <nav class="inst-nav">
        <button
          type="button"
          data-theme-toggle
          class="inst-icon-btn"
          aria-label="Toggle colour theme"
        >
          <svg class="theme-dark-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.4 5.4 0 0 1-7.54-7.54c-.44-.06-.9-.1-1.36-.1Z"/></svg>
          <svg class="theme-light-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0-6h0v3m0 16v3M4.2 4.2 6.3 6.3m11.4 11.4 2.1 2.1M1 12h3m16 0h3M4.2 19.8 6.3 17.7M17.7 6.3l2.1-2.1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></svg>
        </button>
        <a href={profile.githubUrl} target="_blank" rel="noreferrer" class="inst-icon-btn" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path fill="currentColor" d="M12 .5A11.5 11.5 0 0 0 8.36 22.9c.58.1.79-.25.79-.56v-2.02c-3.22.7-3.9-1.38-3.9-1.38-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.04 1.76 2.72 1.25 3.38.96.11-.75.41-1.25.74-1.54-2.57-.29-5.27-1.28-5.27-5.72 0-1.26.45-2.3 1.19-3.1-.12-.3-.52-1.48.11-3.07 0 0 .97-.31 3.16 1.18a10.98 10.98 0 0 1 5.76 0c2.19-1.49 3.15-1.18 3.15-1.18.64 1.59.24 2.77.12 3.07.74.8 1.18 1.84 1.18 3.1 0 4.45-2.7 5.43-5.28 5.72.42.36.79 1.07.79 2.16v3.02c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .5Z"/></svg>
        </a>
        <a href={profile.xUrl} target="_blank" rel="noreferrer" class="inst-icon-btn" aria-label="X">
          <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M18.9 2h3.3l-7.2 8.2L23.5 22h-6.6l-5.2-6.8L5.8 22H2.5l7.7-8.8L2 2h6.8l4.7 6.2L18.9 2Zm-1.2 18h1.8L7.3 3.9H5.4L17.7 20Z"/></svg>
        </a>
      </nav>
    </header>

    <section class="inst-hero">
      <p class="inst-eyebrow">
        <span>{profile.role}</span>
        <span class="inst-sep">/</span>
        <span>{profile.location}</span>
      </p>
      <h1 class="inst-name">{profile.name}</h1>
      <p class="inst-tagline">{profile.tagline}</p>

      <figure class="inst-trace" aria-label="Illustrative request trace">
        <figcaption class="inst-trace-head">
          <span>trace</span>
          <span>request.duration = 78 ms</span>
        </figcaption>
        <div class="inst-scan" aria-hidden="true"></div>
        {
          spans.map((span) => (
            <div class="inst-span-row">
              <span class="inst-span-label">{span.label}</span>
              <span class="inst-span-track">
                <span
                  class={span.root ? "inst-span-bar is-root" : "inst-span-bar"}
                  style={`left:${span.left}%;width:${span.width}%`}
                />
              </span>
              <span class="inst-span-ms">{span.ms}ms</span>
            </div>
          ))
        }
      </figure>
    </section>

    <section class="inst-section">
      <p class="inst-kicker">// what I optimise for</p>
      <div class="inst-focus">
        {
          focus.map((item, i) => (
            <article class="inst-card">
              <span class="inst-card-idx">{String(i + 1).padStart(2, "0")}</span>
              <h2 class="inst-card-title">{item.label}</h2>
              <p class="inst-card-text">{item.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="inst-section">
      <p class="inst-kicker">// stack</p>
      <div class="inst-stack">
        {
          stack.map((col) => (
            <div class="inst-stack-col">
              <h3 class="inst-stack-group">{col.group}</h3>
              <ul class="inst-stack-list">
                {col.items.map((item) => (
                  <li>
                    <span class="inst-tick" aria-hidden="true">▸</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <footer class="inst-footer">
      <p class="inst-about">{profile.about}</p>
      <div class="inst-footer-links">
        <a href={profile.githubUrl} target="_blank" rel="noreferrer">github.com/{profile.handle} →</a>
        <a href={profile.xUrl} target="_blank" rel="noreferrer">x.com/sapirowski →</a>
      </div>
    </footer>
  </main>

  <style is:global>
    html[data-theme="dark"] .inst {
      --bg: #0a0c0e;
      --panel: #12161a;
      --line: rgba(255, 255, 255, 0.09);
      --fg: #e7ebee;
      --muted: #838d95;
      --accent: #ffb000;
      --accent-soft: rgba(255, 176, 0, 0.16);
      --grain: 0.04;
    }
    html[data-theme="light"] .inst {
      --bg: #f2efe8;
      --panel: #ffffff;
      --line: rgba(20, 24, 27, 0.12);
      --fg: #14181b;
      --muted: #626b72;
      --accent: #9a5b00;
      --accent-soft: rgba(154, 91, 0, 0.1);
      --grain: 0.03;
    }

    .inst {
      position: relative;
      min-height: 100svh;
      background: var(--bg);
      color: var(--fg);
      font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
      overflow-x: hidden;
      transition: background 0.4s ease, color 0.4s ease;
    }
    .inst-grain {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: var(--grain);
      background-image: radial-gradient(currentColor 0.5px, transparent 0.5px);
      background-size: 3px 3px;
      color: var(--fg);
    }
    .inst > *:not(.inst-grain) {
      position: relative;
      z-index: 1;
    }

    .inst-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1120px;
      margin: 0 auto;
      padding: 22px 28px;
    }
    .inst-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.9rem;
      letter-spacing: 0.02em;
    }
    .inst-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 0 var(--accent-soft);
      animation: inst-pulse 2.6s ease-out infinite;
    }
    @keyframes inst-pulse {
      0% { box-shadow: 0 0 0 0 var(--accent-soft); }
      70% { box-shadow: 0 0 0 7px transparent; }
      100% { box-shadow: 0 0 0 0 transparent; }
    }
    .inst-nav {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .inst-icon-btn {
      display: grid;
      place-items: center;
      width: 40px;
      height: 40px;
      border: 1px solid var(--line);
      border-radius: 9px;
      color: var(--fg);
      background: transparent;
      cursor: pointer;
      transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    }
    .inst-icon-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
    .inst-icon-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    html[data-theme="dark"] .theme-light-icon { display: none; }
    html[data-theme="light"] .theme-dark-icon { display: none; }

    .inst-hero {
      max-width: 1120px;
      margin: 0 auto;
      padding: clamp(40px, 9vw, 96px) 28px clamp(48px, 8vw, 80px);
    }
    .inst-eyebrow {
      display: flex;
      gap: 12px;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: var(--muted);
      margin: 0 0 26px;
    }
    .inst-sep { color: var(--accent); }
    .inst-name {
      font-family: "Space Grotesk", sans-serif;
      font-weight: 600;
      font-size: clamp(2.9rem, 9vw, 6.2rem);
      line-height: 0.94;
      letter-spacing: -0.03em;
      margin: 0;
    }
    .inst-tagline {
      max-width: 34ch;
      margin: 26px 0 0;
      font-size: clamp(1.05rem, 2.4vw, 1.4rem);
      line-height: 1.5;
      color: var(--muted);
    }

    .inst-trace {
      margin: clamp(40px, 6vw, 64px) 0 0;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--panel);
      padding: 20px clamp(18px, 3vw, 28px) 24px;
      position: relative;
      overflow: hidden;
    }
    .inst-trace-head {
      display: flex;
      justify-content: space-between;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.76rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      padding-bottom: 16px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 14px;
    }
    .inst-scan {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 1px;
      background: var(--accent);
      opacity: 0.5;
      left: 0;
      animation: inst-scan 6s linear infinite;
    }
    @keyframes inst-scan {
      0% { left: 0; opacity: 0; }
      8% { opacity: 0.55; }
      92% { opacity: 0.55; }
      100% { left: 100%; opacity: 0; }
    }
    .inst-span-row {
      display: grid;
      grid-template-columns: minmax(120px, 1.1fr) 3fr auto;
      align-items: center;
      gap: 14px;
      padding: 7px 0;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.82rem;
    }
    .inst-span-label {
      color: var(--fg);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .inst-span-track {
      position: relative;
      height: 10px;
      border-radius: 3px;
      background: color-mix(in srgb, var(--fg) 6%, transparent);
    }
    .inst-span-bar {
      position: absolute;
      top: 0;
      height: 10px;
      border-radius: 3px;
      background: color-mix(in srgb, var(--accent) 45%, transparent);
    }
    .inst-span-bar.is-root {
      background: var(--accent);
    }
    .inst-span-ms {
      color: var(--muted);
      text-align: right;
      min-width: 42px;
    }

    .inst-section {
      max-width: 1120px;
      margin: 0 auto;
      padding: clamp(30px, 5vw, 56px) 28px;
    }
    .inst-kicker {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin: 0 0 26px;
    }
    .inst-focus {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
      border-radius: 14px;
      overflow: hidden;
    }
    .inst-card {
      background: var(--bg);
      padding: 28px clamp(20px, 2.5vw, 30px) 32px;
      transition: background 0.25s ease;
    }
    .inst-card:hover { background: var(--panel); }
    .inst-card-idx {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.8rem;
      color: var(--accent);
    }
    .inst-card-title {
      font-family: "Space Grotesk", sans-serif;
      font-weight: 600;
      font-size: 1.3rem;
      letter-spacing: -0.01em;
      margin: 18px 0 12px;
    }
    .inst-card-text {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.96rem;
    }

    .inst-stack {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 28px;
    }
    .inst-stack-group {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin: 0 0 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line);
    }
    .inst-stack-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .inst-stack-list li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.98rem;
    }
    .inst-tick { color: var(--accent); font-size: 0.7rem; }

    .inst-footer {
      max-width: 1120px;
      margin: 0 auto;
      padding: clamp(40px, 6vw, 72px) 28px clamp(48px, 8vw, 90px);
      border-top: 1px solid var(--line);
      display: grid;
      gap: 32px;
    }
    .inst-about {
      max-width: 62ch;
      margin: 0;
      font-size: clamp(1.05rem, 2vw, 1.3rem);
      line-height: 1.65;
      color: var(--fg);
    }
    .inst-footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.9rem;
    }
    .inst-footer-links a {
      color: var(--muted);
      transition: color 0.2s ease;
    }
    .inst-footer-links a:hover { color: var(--accent); }
    .inst-footer-links a:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }

    @media (max-width: 560px) {
      .inst-span-row { grid-template-columns: 1fr auto; }
      .inst-span-track { display: none; }
    }
  </style>
</PreviewLayout>
