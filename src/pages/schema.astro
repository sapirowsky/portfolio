---
import PreviewLayout from "../layouts/PreviewLayout.astro";
import { focus, profile, stack } from "../data/profile";
---

<PreviewLayout
  title={`${profile.name} — ${profile.role}`}
  description={profile.tagline}
>
  <main class="sch">
    <header class="sch-bar">
      <a href="/" class="sch-brand"><span class="sch-kw">import</span> {profile.handle}</a>
      <nav class="sch-nav">
        <button type="button" data-theme-toggle class="sch-btn" aria-label="Toggle colour theme">
          <svg class="theme-dark-icon" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.4 5.4 0 0 1-7.54-7.54c-.44-.06-.9-.1-1.36-.1Z"/></svg>
          <svg class="theme-light-icon" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0-6h0v3m0 16v3M4.2 4.2 6.3 6.3m11.4 11.4 2.1 2.1M1 12h3m16 0h3M4.2 19.8 6.3 17.7M17.7 6.3l2.1-2.1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></svg>
        </button>
        <a href={profile.githubUrl} target="_blank" rel="noreferrer" class="sch-btn" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M12 .5A11.5 11.5 0 0 0 8.36 22.9c.58.1.79-.25.79-.56v-2.02c-3.22.7-3.9-1.38-3.9-1.38-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.04 1.76 2.72 1.25 3.38.96.11-.75.41-1.25.74-1.54-2.57-.29-5.27-1.28-5.27-5.72 0-1.26.45-2.3 1.19-3.1-.12-.3-.52-1.48.11-3.07 0 0 .97-.31 3.16 1.18a10.98 10.98 0 0 1 5.76 0c2.19-1.49 3.15-1.18 3.15-1.18.64 1.59.24 2.77.12 3.07.74.8 1.18 1.84 1.18 3.1 0 4.45-2.7 5.43-5.28 5.72.42.36.79 1.07.79 2.16v3.02c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .5Z"/></svg>
        </a>
        <a href={profile.xUrl} target="_blank" rel="noreferrer" class="sch-btn" aria-label="X">
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M18.9 2h3.3l-7.2 8.2L23.5 22h-6.6l-5.2-6.8L5.8 22H2.5l7.7-8.8L2 2h6.8l4.7 6.2L18.9 2Zm-1.2 18h1.8L7.3 3.9H5.4L17.7 20Z"/></svg>
        </a>
      </nav>
    </header>

    <section class="sch-hero">
      <div class="sch-decl">
        <span class="sch-kw">type</span> <span class="sch-type">Engineer</span> <span class="sch-punc">= {'{'}</span>
      </div>
      <div class="sch-hero-row">
        <span class="sch-key">name:</span>
        <h1 class="sch-name">{profile.name}</h1>
      </div>
      <p class="sch-tagline">
        <span class="sch-key">building:</span>
        <span class="sch-str">“{profile.tagline}”</span>
      </p>
      <p class="sch-meta">
        <span class="sch-key">role:</span> <span class="sch-str">“{profile.role}”</span>
        <span class="sch-punc">,</span>
        <span class="sch-key sch-ml">lang:</span> <span class="sch-str">“Polish”</span>
      </p>
      <div class="sch-decl sch-close"><span class="sch-punc">{'}'}</span></div>
    </section>

    <section class="sch-section">
      <p class="sch-comment">// end-to-end typed, observable, tested</p>
      <div class="sch-decl">
        <span class="sch-kw">const</span> <span class="sch-var">priorities</span><span class="sch-punc">:</span> <span class="sch-type">Focus</span><span class="sch-punc">[] = [</span>
      </div>
      <div class="sch-grid">
        {
          focus.map((item) => (
            <article class="sch-item">
              <div class="sch-item-head">
                <span class="sch-punc">{'{'}</span>
                <span class="sch-key">title:</span>
                <span class="sch-str">“{item.label}”</span>
              </div>
              <p class="sch-item-text">{item.text}</p>
              <span class="sch-punc sch-item-close">{'},'}</span>
            </article>
          ))
        }
      </div>
      <div class="sch-decl"><span class="sch-punc">]</span></div>
    </section>

    <section class="sch-section">
      <p class="sch-comment">// tools I reach for</p>
      <div class="sch-decl">
        <span class="sch-kw">type</span> <span class="sch-type">Stack</span> <span class="sch-punc">= {'{'}</span>
      </div>
      <div class="sch-stack">
        {
          stack.map((col) => (
            <div class="sch-stack-row">
              <span class="sch-key sch-stack-key">{col.group.toLowerCase()}:</span>
              <span class="sch-stack-items">
                <span class="sch-punc">[</span>
                {col.items.map((item, i) => (
                  <>
                    <span class="sch-str">“{item}”</span>
                    {i < col.items.length - 1 && <span class="sch-punc">, </span>}
                  </>
                ))}
                <span class="sch-punc">]</span>
              </span>
            </div>
          ))
        }
      </div>
      <div class="sch-decl"><span class="sch-punc">{'}'}</span></div>
    </section>

    <footer class="sch-footer">
      <p class="sch-doc-open">/**</p>
      <p class="sch-about"><span class="sch-doc-star">*</span> {profile.about}</p>
      <p class="sch-doc-open">*/</p>
      <div class="sch-links">
        <a href={profile.githubUrl} target="_blank" rel="noreferrer">
          <span class="sch-kw">github</span> → /{profile.handle}
        </a>
        <a href={profile.xUrl} target="_blank" rel="noreferrer">
          <span class="sch-kw">x</span> → /sapirowski
        </a>
      </div>
    </footer>
  </main>

  <style is:global>
    html[data-theme="light"] .sch {
      --bg: #f7f6f2;
      --fg: #1b1a16;
      --muted: #6c6a61;
      --line: rgba(27, 26, 22, 0.11);
      --panel: #fffefb;
      --kw: #8a3ffc;
      --type: #1f6feb;
      --str: #1a7f52;
      --var: #b0530f;
      --punc: #9a978c;
    }
    html[data-theme="dark"] .sch {
      --bg: #141417;
      --fg: #e8e7e2;
      --muted: #8b8a92;
      --line: rgba(255, 255, 255, 0.1);
      --panel: #1b1b1f;
      --kw: #c9a6ff;
      --type: #79b0ff;
      --str: #74d6a3;
      --var: #f0a868;
      --punc: #6a6972;
    }

    .sch {
      min-height: 100svh;
      background: var(--bg);
      color: var(--fg);
      font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
      transition: background 0.4s ease, color 0.4s ease;
    }
    .sch-kw { color: var(--kw); }
    .sch-type { color: var(--type); }
    .sch-str { color: var(--str); }
    .sch-var { color: var(--var); }
    .sch-punc { color: var(--punc); }
    .sch-key { color: var(--muted); }

    .sch-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1000px;
      margin: 0 auto;
      padding: 22px 28px;
    }
    .sch-brand {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.9rem;
    }
    .sch-nav { display: flex; align-items: center; gap: 6px; }
    .sch-btn {
      display: grid;
      place-items: center;
      width: 38px;
      height: 38px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: transparent;
      color: var(--fg);
      cursor: pointer;
      transition: border-color 0.2s ease, color 0.2s ease;
    }
    .sch-btn:hover { border-color: var(--kw); color: var(--kw); }
    .sch-btn:focus-visible { outline: 2px solid var(--kw); outline-offset: 3px; }
    html[data-theme="dark"] .theme-light-icon { display: none; }
    html[data-theme="light"] .theme-dark-icon { display: none; }

    .sch-hero {
      max-width: 1000px;
      margin: 0 auto;
      padding: clamp(44px, 9vw, 104px) 28px clamp(40px, 7vw, 72px);
    }
    .sch-decl {
      font-family: "IBM Plex Mono", monospace;
      font-size: clamp(0.95rem, 2vw, 1.15rem);
      letter-spacing: -0.01em;
    }
    .sch-close { margin-top: 20px; }
    .sch-hero-row {
      display: flex;
      align-items: baseline;
      gap: 18px;
      flex-wrap: wrap;
      margin: 18px 0 6px;
      padding-left: clamp(16px, 4vw, 40px);
    }
    .sch-hero-row .sch-key {
      font-family: "IBM Plex Mono", monospace;
      font-size: clamp(0.95rem, 2vw, 1.15rem);
    }
    .sch-name {
      margin: 0;
      font-family: "IBM Plex Sans", sans-serif;
      font-weight: 600;
      font-size: clamp(2.6rem, 8.5vw, 5.6rem);
      line-height: 0.98;
      letter-spacing: -0.035em;
      color: var(--str);
    }
    .sch-tagline,
    .sch-meta {
      font-family: "IBM Plex Mono", monospace;
      padding-left: clamp(16px, 4vw, 40px);
      margin: 14px 0 0;
      line-height: 1.6;
      font-size: clamp(0.95rem, 2vw, 1.1rem);
    }
    .sch-meta { color: var(--muted); font-size: 0.92rem; }
    .sch-ml { margin-left: 14px; }

    .sch-section {
      max-width: 1000px;
      margin: 0 auto;
      padding: clamp(28px, 5vw, 56px) 28px;
    }
    .sch-comment {
      font-family: "IBM Plex Mono", monospace;
      color: var(--muted);
      opacity: 0.85;
      margin: 0 0 14px;
      font-size: 0.9rem;
    }
    .sch-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 14px;
      padding: 18px 0 18px clamp(16px, 4vw, 40px);
    }
    .sch-item {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--panel);
      padding: 20px 22px 18px;
      transition: border-color 0.25s ease, transform 0.25s ease;
    }
    .sch-item:hover { border-color: var(--kw); transform: translateY(-3px); }
    .sch-item-head {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.9rem;
      display: flex;
      gap: 7px;
      flex-wrap: wrap;
      align-items: baseline;
      margin-bottom: 12px;
    }
    .sch-item-text {
      margin: 0;
      color: var(--fg);
      line-height: 1.6;
      font-size: 0.98rem;
    }
    .sch-item-close {
      display: inline-block;
      margin-top: 14px;
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.9rem;
    }

    .sch-stack {
      padding: 18px 0 18px clamp(16px, 4vw, 40px);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .sch-stack-row {
      font-family: "IBM Plex Mono", monospace;
      font-size: clamp(0.85rem, 1.8vw, 1rem);
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: baseline;
    }
    .sch-stack-key { min-width: 96px; }

    .sch-footer {
      max-width: 1000px;
      margin: 0 auto;
      padding: clamp(36px, 6vw, 72px) 28px clamp(48px, 8vw, 96px);
    }
    .sch-doc-open {
      font-family: "IBM Plex Mono", monospace;
      color: var(--punc);
      margin: 0;
    }
    .sch-about {
      font-family: "IBM Plex Mono", monospace;
      max-width: 70ch;
      margin: 4px 0;
      padding-left: 8px;
      line-height: 1.75;
      font-size: clamp(0.98rem, 2vw, 1.12rem);
      color: var(--fg);
    }
    .sch-doc-star { color: var(--punc); margin-right: 8px; }
    .sch-links {
      margin-top: 34px;
      display: flex;
      flex-wrap: wrap;
      gap: 28px;
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.95rem;
    }
    .sch-links a {
      color: var(--fg);
      border-bottom: 1px solid var(--line);
      padding-bottom: 3px;
      transition: border-color 0.2s ease;
    }
    .sch-links a:hover { border-color: var(--kw); }
    .sch-links a:focus-visible { outline: 2px solid var(--kw); outline-offset: 3px; }
  </style>
</PreviewLayout>
